{
  "manifest_version": 3,
  "name": "GHL Workflow Screenshotter",
  "version": "0.1.0",
  "description": "Capture a full-resolution screenshot of an entire GoHighLevel workflow.",
  "action": { "default_title": "Capture workflow screenshot" },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://*.leadconnectorhq.com/*"],
  "content_scripts": [
    {
      "matches": ["https://client-app-automation-workflows.leadconnectorhq.com/*"],
      "all_frames": true,
      "run_at": "document_idle",
      "js": ["src/geometry.js", "src/naming.js", "src/overlay.js", "src/content.js", "src/button.js"]
    }
  ],
  "background": { "service_worker": "src/background.js" }
}
